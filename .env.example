# Auralis — application configuration
# Copy to .env and adjust as needed

APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8104

# CORS — comma-separated list. Wildcard "*" only in development.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8104

# Static frontend build directory (served by FastAPI when present)
FRONTEND_DIST=frontend/dist

# Data manifest path (root for sounds + per-sound embeddings)
DATA_DIR=data

# Caching
CACHE_TTL_MANIFEST=3600
